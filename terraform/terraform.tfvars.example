# --- PROJEKT EINSTELLUNGEN ---
project_id = "dein-gcp-projekt-id"
region     = "us-central1"

# --- DATENBANK (ALLOYDB) ---
# Das Passwort für den 'postgres' User in der AlloyDB
db_password = "ein-sehr-sicheres-passwort-hier-einsetzen"

# --- SICHERHEIT (API SECRETS) ---
# Diese Keys müssen im HTTP-Header 'X-API-Secret: <secret>' mitgesendet werden.
# Tipp: Generiere lange Zufallsstrings (z.B. mit 'openssl rand -base64 32')

# Secret für die Validierungs-Funktion (Eingang)
api_secret_validation = "generiere-einen-zufalls-string-fuer-validation"

# Secret für die Worker-Funktion (interner Check)
api_secret_worker = "generiere-einen-zufalls-string-fuer-worker"

# --- ZUGRIFFSKONTROLLE ---
# Wer darf die API aufrufen? 
# Falls leer, ist die API nicht öffentlich erreichbar.
# Format: 'user:dein-name@gmail.com', 'group:team@ihredomain.de', 'serviceAccount:xyz@project.iam.gserviceaccount.com'
authorized_invokers = [
  "user:dein-name@gmail.com",
  "user:kollege-name@gmail.com"
]
